generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres.iajjpsiicjecbukyfxvr:NRjJ9aliA3NT0k2x@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
}

model assets {
  id                             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  asset_tag_id                   String      @unique @db.VarChar(255)
  name                           String?     @db.VarChar(255)
  description                    String?
  serial_number                  String?     @db.VarChar(255)
  brand                          String?     @db.VarChar(255)
  model                          String?     @db.VarChar(255)
  cost                           Decimal?    @db.Decimal(15, 2)
  purchase_date                  DateTime?   @db.Date
  date_acquired                  DateTime?   @db.Date
  category                       String?     @db.VarChar(255)
  sub_category                   String?     @db.VarChar(255)
  location                       String?     @db.VarChar(255)
  site                           String?     @db.VarChar(255)
  department                     String?     @db.VarChar(255)
  status                         String?     @default("Available") @db.VarChar(50)
  assigned_to                    String?     @db.VarChar(255)
  asset_type                     String?     @db.VarChar(255)
  notes                          String?
  image_url                      String?
  image_file_name                String?     @db.VarChar(255)
  created_at                     DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime?   @default(now()) @db.Timestamptz(6)
  created_by                     String?     @db.Uuid
  updated_by                     String?     @db.Uuid
  manufacturer                   String?     @db.VarChar(255)

  @@index([asset_tag_id], map: "idx_assets_asset_tag_id")
  @@index([assigned_to], map: "idx_assets_assigned_to")
  @@index([category], map: "idx_assets_category")
  @@index([created_at], map: "idx_assets_created_at")
  @@index([department], map: "idx_assets_department")
  @@index([location], map: "idx_assets_location")
  @@index([manufacturer], map: "idx_assets_manufacturer")
  @@index([serial_number], map: "idx_assets_serial_number")
  @@index([status], map: "idx_assets_status")
}

model maintenance_records {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  asset_id             String
  maintenance_title    String
  maintenance_details  String?
  maintenance_due_date DateTime  @db.Date
  maintenance_by       String
  status               String    @default("scheduled")
  date_completed       DateTime? @db.Date
  maintenance_cost     Decimal?  @default(0) @db.Decimal(10, 2)
  is_repeating         Boolean?  @default(false)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)

  @@index([asset_id], map: "idx_maintenance_records_asset_id")
  @@index([created_at], map: "idx_maintenance_records_created_at")
  @@index([maintenance_due_date], map: "idx_maintenance_records_due_date")
  @@index([status], map: "idx_maintenance_records_status")
}

model users {
  id         String   @id @db.Uuid
  user_type  String
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  @@index([user_type], map: "idx_users_user_type")
}

model company_info {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company              String    @db.VarChar(255)
  organization_type    String?   @db.VarChar(255)
  country              String?   @db.VarChar(255)
  address              String?
  apt_suite            String?   @db.VarChar(255)
  city                 String?   @db.VarChar(255)
  state                String?   @db.VarChar(255)
  postal_code          String?   @db.VarChar(50)
  timezone             String?   @db.VarChar(100)
  currency             String?   @db.VarChar(10)
  logo_url             String?
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @default(now()) @db.Timestamptz(6)
}

